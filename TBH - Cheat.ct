</AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>38</ID>
              <Description>"Exp"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{  Game Executable   : TaskBarHero.exe
   Script Date       : 2026-06-21
   Author            : Jonxpin
}
 
{$lua}
if syntaxcheck then return end
 
[ENABLE]
local pat = "F3 0F 58 ?? ?? 33 ?? ?? 8D ?? 24 ?? 0F 28 ?? E8 ?? ?? ?? ?? 8B ?? 10 0F 10"
local modBase = getAddress("GameAssembly.dll")
local modSize = getModuleSize("GameAssembly.dll")
local r = AOBScan(pat, "+X-C-W", 0, modBase, modBase + modSize)
if not r or r.Count == 0 then print("Exp: pattern not found") return end
local n = r.Count
 
local block = allocateMemory(8 + n * 32, modBase)
writeFloat(block, 1.0)
unregisterSymbol("xpmult")
registerSymbol("xpmult", block, true)
 
_G.expN = n
_G.expBlock = block
_G.expAddrs = {}
_G.expOrig = {}
 
local function b4(v)
    v = v % 0x100000000
    return v%256, math.floor(v/256)%256, math.floor(v/65536)%256, math.floor(v/16777216)%256
end
 
for i = 0, n-1 do
    local addr = getAddress(r[i])
    _G.expAddrs[i] = addr
    _G.expOrig[i] = readBytes(addr, 7, true)
    local tramp = block + 8 + i*32
    local o0,o1,o2,o3 = b4(block-(tramp+8))
    writeBytes(tramp+0,  {0xF3,0x0F,0x59,0x05,o0,o1,o2,o3})
    writeBytes(tramp+8,  {0xF3,0x0F,0x58,0xC6})
    writeBytes(tramp+12, {0x45,0x33,0xC0})
    writeBytes(tramp+15, {0xFF,0x25,0x00,0x00,0x00,0x00})
    local ret = addr+7
    local r0,r1,r2,r3 = b4(ret)
    local r4,r5,r6,r7 = b4(math.floor(ret/0x100000000))
    writeBytes(tramp+21, {r0,r1,r2,r3,r4,r5,r6,r7})
    local j0,j1,j2,j3 = b4(tramp-(addr+5))
    writeBytes(addr, {0xE9,j0,j1,j2,j3,0x90,0x90})
end
r.destroy()
 
[DISABLE]
for i = 0, (_G.expN or 0)-1 do
    local addr = _G.expAddrs and _G.expAddrs[i]
    local orig = _G.expOrig and _G.expOrig[i]
    if addr and orig then writeBytes(addr, orig) end
end
unregisterSymbol("xpmult")
if _G.expBlock then deAlloc(_G.expBlock) end
_G.expBlock = nil
_G.expAddrs = nil
_G.expOrig = nil
_G.expN = nil
</AssemblerScript>
