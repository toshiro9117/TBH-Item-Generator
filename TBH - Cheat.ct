[ENABLE]
 
aobscanmodule(cubexp,GameAssembly.dll,F3 0F 58 ?? ?? 33 ?? ?? 8D ?? 24 ?? 0F 28 ?? E8 ?? ?? ?? ?? 0F 10 ?? 8B ?? 10)
alloc(newmem,$1000,cubexp)
alloc(cubexpo,$7)
label(return)
label(cubeExpValue)
registersymbol(cubexpo)
registersymbol(cubeExpValue)
 
cubexpo:
  readmem(cubexp,7)
newmem:
  mulss xmm6,[cubeExpValue]
  reassemble(cubexp)
  reassemble(cubexp+4)
  jmp return
  align 10 cc
 
